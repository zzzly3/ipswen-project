	dest.bytes[2] = 253;
	dest.bytes[3] = 0;
	// dest.bytes[4] = 128;
	// dest.ext.level = 1;

	memset(&gate, 0, sizeof(struct ipswen_addr));
	gate.bytes[0] = 192;
	gate.bytes[1] = 168;
	gate.bytes[2] = 1;
	gate.bytes[3] = 131;

	route_add(fd, &dest, &gate, 24);
	return 0;
}