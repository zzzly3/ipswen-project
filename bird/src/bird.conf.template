@begin
import os
import networkx
from control import get_nodes
this = int(getenv("id"))
nodes = get_nodes()
nets = [i for i in nodes.keys() if isinstance(i, str)]
G = networkx.Graph()
G.add_node(this)



G.add_edge(1, 2)
G.add_edge(2, 3)
G.add_edge(2, 4)
G.add_edge(3, 4)

G.add_edge(10, 12)
G.add_edge(12, 14)
G.add_edge(12, 13)
G.add_edge(13, 14)
G.add_edge(14, 11)

G.add_edge(21, 22)
G.add_edge(22, 23)
G.add_edge(21, 23)
G.add_edge(20, 23)

G.add_edge(1, 11)
G.add_edge(1, 20)
G.add_edge(11, 20)

G.add_edge(10, 13)
G.add_edge(10, 14)




def peer_ip(peer):
    for net in nets:
        f1 = None
        f2 = None
        for node in nodes[net]:
            if node['id'] == this:
                f1 = node['ip']
            if node['id'] == peer:
                f2 = node['ip']
        if f1 is not None and f2 is not None:
            return f2
    return nodes[peer]['ip'] # inter-domain
@end

debug protocols all;

log "bird.log" all;

