@begin
bgp = '''
protocol bgp from bgp0 {
    neighbor %s as %d;
}
'''
for i in G.neighbors(this):
    echo(bgp % (peer_ip(i), 65100 + i))



# make graph
if this == 1:
    import matplotlib.pyplot as plt
    pos = networkx.spring_layout(G)
    networkx.draw(G, pos, with_labels=True, font_size=10, node_size=500, node_color='lightblue')
